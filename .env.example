# Build the private /login and /dashboard routes.
# Runtime access still requires a Neon Auth account in public.admin_users.
VITE_ENABLE_DEV_DASHBOARD=false

# Bypass authentication with a mock admin account. Use only for local testing;
# requires VITE_ENABLE_DEV_DASHBOARD=true to expose the dashboard routes.
# Disabling auth does NOT authorize database writes: pair it with
# VITE_DASHBOARD_PUBLISH_MODE=export for local mock-auth work.
VITE_DISABLE_AUTH=false

# Publish valid dashboard drafts directly to Neon by default.
# Set to export only for the legacy ZIP recovery/development workflow.
VITE_DASHBOARD_PUBLISH_MODE=database

# Public Neon endpoints from the project's Auth and Data API configuration.
# No database connection string or Neon API key belongs in a VITE_* variable.
VITE_NEON_AUTH_URL=
VITE_NEON_DATA_API_URL=
